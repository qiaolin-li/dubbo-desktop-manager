{
  "name": "dubbo-desktop-manager",
  "productName": "dubbo-desktop-manager",
  "description": "一个Dubbo管理客户端",
  "author": {
    "name": "qiaolin",
    "email": "992004863@qq.com",
    "url": "https://github.com/qiaolin-li/dubbo-desktop-manager"
  },
  "version": "2.0.0",
  "private": true,
  "port": {
    "dev": 34567,
    "prod": 34568
  },
  "scripts": {
    "lint": "eslint --ext .js,.vue src",
    "format": "prettier --write \"src/**/*.{js,vue,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,json}\"",
    "build": "electron-vite build && electron-builder",
    "debugStart": "(chcp 65001 || true) && electron-vite dev --inspect=5858",
    "start": "(chcp 65001 || true) && electron-vite dev",
    "postinstall": "patch-package && electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps",
    "publish:plugin-api": "npm publish ./packages/plugin-api --access public",
    "publish:create-plugin": "npm publish ./packages/create-ddm-plugin --access public",
    "publish:plugin-tools": "npm run publish:plugin-api && npm run publish:create-plugin",
    "release": "electron-vite build && electron-builder --publish always",
    "patch": "npm version patch && git push origin master && git push origin --tags",
    "minor": "npm version minor && git push origin master && git push origin --tags",
    "major": "npm version major && git push origin master && git push origin --tags"
  },
  "main": "out/main/background.js",
  "dependencies": {
    "@electron/remote": "^2.0.1",
    "axios": "^0.26.0",
    "fs-extra": "^10.1.0",
    "log4js": "^6.9.1",
    "lowdb": "^1.0.0",
    "nedb": "^1.8.0",
    "vue-i18n": "6.0.0",
    "telnet-stream": "^1.0.5",
    "os-locale": "^5.0.0",
    "jq-wasm": "^1.1.0-jq-1.8.1",
    "js-yaml": "^4.1.0",
    "lodash-es": "^4.18.1",
    "json-bigint": "^1.0.0",
    "jsonc-parser": "^3.3.1",
    "jsonpath-plus": "^10.4.0",
    "jq-web": "^0.6.2"
  },
  
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.0",
    "@types/lowdb": "^1.0.11",
    "@vitejs/plugin-vue2": "^2.3.4",
    "@vue/composition-api": "^1.7.2",
    "electron": "^25.9.8",
    "electron-builder": "^23.0.6",
    "electron-devtools-installer": "^3.1.0",
    "electron-vite": "^5.0.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-vue": "^7.20.0",
    "prettier": "^3.6.2",
    "patch-package": "^6.4.7",
    
    "codemirror": "^5.64.0",
    "element-ui": "2.15.14",
    "markdown-it-replace-link": "^1.2.1",
    "mavon-editor": "^2.10.4",
    "moment": "^2.29.1",
    "monaco-editor": "^0.52.2",
    "mousetrap": "^1.6.5",
    "npm": "8.19.4",
    "pinia": "^2.3.1",
    "sortablejs": "^1.15.0",
    "vite": "^6",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vue": "^2.6.11",
    "vue-codemirror": "^4.0.6",
    "vue-infinite-scroll": "^2.0.2",
    "vue-template-compiler": "^2.6.11",
    "xterm": "^4.17.0",
    "xterm-addon-fit": "^0.5.0",
    "xterm-addon-search": "^0.8.2"
  },
  "initPlugins": {
    "ddm-plugin-dubbo-support": "0.3.0"
  },
  "resolutions": {
    "**/commander": "11.1.0",
    "**/minimatch": "3.1.2",
    "**/@achrinza/node-ipc": "9.2.9"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended",
      "prettier"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser",
      "requireConfigFile": false
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "overrides": {
    "htmlparser2": "8.0.2"
  },
  "build": {
    "productName": "Dubbo-Desktop-Manager",
    "appId": "indi.qiaolin.dubbo.desktop.manager",
    "copyright": "Copyright © 2021-2099 qiaolin",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "out/**/*",
      {
        "from": "public/plugins",
        "to": "plugins"
      },
      "package.json"
    ],
    "afterPack": "./build/afterPack.js",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true,
    "extraResources": [
      "./node_modules/npm"
    ],
    "asarUnpack": [
      "./jar/**",
      "./plugins/**"
    ]
  }
}
